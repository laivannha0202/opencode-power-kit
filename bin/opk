#!/usr/bin/env bash
# ============================================================================
# OpenCode Power Kit - opk CLI wrapper
# Thin wrapper gọi lại các script có sẵn trong kit. Không duplicate logic.
# v2.0.0: thêm upstream/superpowers/bmad/tooling/taste subcommands.
#
# Usage:
#   opk help
#   opk version
#   opk path
#   opk global        # cài global
#   opk install       # cài vào project hiện tại (= opk project = opk init)
#   opk init          # alias: opk install
#   opk quick         # alias: opk global (with --yes)
#   opk fullstack     # cài full-stack profile
#   opk all           # cài tất cả (cần pwd = project dir)
#   opk doctor        # chẩn đoán
#   opk verify        # kiểm tra project
#   opk tools         # install-token-tools (rtk/tokscale)
#   opk bootstrap     # gọi bootstrap.sh
#   opk one           # alias: bootstrap.sh --all --project-dir "$(pwd)" --yes (all-in-one)
#   opk go            # alias: opk one
#   opk up            # update kit + project (One Command Update)
#   opk update        # alias: opk up
#   opk upgrade       # alias: opk up
#   opk clean         # cleanup project artifacts (dry-run mặc định)
#   opk up --clean    # update + cleanup apply
#   opk mode          # quản lý Power/Safe mode
#   opk mode show     # xem mode hiện tại
#   opk mode power    # chuyển sang Power Mode (permission: allow)
#   opk mode safe     # chuyển sang Safe Mode (permission object)
#   opk safety-plugin # quản lý safety plugin guard
#   opk upstream      # upstream audit/doctor
#   opk superpowers   # superpowers status/reset-cache/doctor
#   opk bmad          # bmad status/update
#   opk tooling       # tooling doctor
#   opk taste         # taste install/status/doctor
# ============================================================================
set -euo pipefail

# --- Resolve kit dir from this script location ---
SELF="${BASH_SOURCE[0]}"
OPK_BIN_DIR="$(cd "$(dirname "$SELF")" && pwd)"

# When installed to ~/.local/bin/opk, the parent dir is ~/.local (not the kit).
# In that case the shim sets OPK_KIT_DIR; fall back to that.
if [ -n "${OPK_KIT_DIR:-}" ] && [ -f "$OPK_KIT_DIR/install.sh" ]; then
  KIT_DIR="$OPK_KIT_DIR"
else
  KIT_DIR="$(cd "$OPK_BIN_DIR/.." && pwd)"
fi

# Sanity check
if [ ! -f "$KIT_DIR/install.sh" ] || [ ! -f "$KIT_DIR/install-global.sh" ]; then
  echo "opk: không tìm thấy opencode-power-kit tại $KIT_DIR" >&2
  echo "      Có thể bạn đang chạy từ ngoài kit. Hãy 'cd ~/opencode-power-kit' rồi chạy lại," >&2
  echo "      hoặc export OPK_KIT_DIR=/đường/dẫn/đến/opencode-power-kit" >&2
  exit 1
fi

VERSION="$(cat "$KIT_DIR/VERSION" 2>/dev/null || echo "?")"

# --- Helpers: output format ---
err()   { echo "opk: $*" >&2; exit 1; }
warn()  { echo "opk: $*" >&2; }
info()  { echo "opk: $*"; }

require_file() {
  [ -f "$1" ] || err "thiếu file: $1"
}

# --- Safety: per-project install KHONG chay trong cac root nguy hiem ---
# Tranh: user chay nham tu $HOME, /, /tmp, /var/tmp, /usr, /etc, hoac
# chinh repo kit. Refuse som de tranh ghi AGENTS.md / .opencode o sai cho.
HOME_DIR="${HOME:-/root}"
is_bad_project_dir() {
  local pwd_real
  pwd_real="$(pwd -P 2>/dev/null || pwd)"
  case "$pwd_real" in "$HOME_DIR"|"$HOME_DIR/"|/) return 0 ;; esac
  case "$pwd_real" in "$KIT_DIR"|"$KIT_DIR/"|"$KIT_DIR"/*)
    case "$pwd_real" in "$KIT_DIR"/.tmp|"$KIT_DIR"/.tmp/*) return 1 ;; esac
    case "$pwd_real" in "$KIT_DIR"/.test|"$KIT_DIR"/.test/*) return 1 ;; esac
    return 0
    ;;
  esac
  case "$pwd_real" in /tmp|/tmp/*) return 0 ;; esac
  case "$pwd_real" in /var/tmp|/var/tmp/*) return 0 ;; esac
  case "$pwd_real" in /usr|/usr/*) return 0 ;; esac
  case "$pwd_real" in /etc|/etc/*) return 0 ;; esac
  return 1
}

explain_blocked_dir() {
  local pwd_now
  pwd_now="$(pwd)"
  echo "" >&2
  echo "opk: TU CHOI cai vao: $pwd_now" >&2
  echo "" >&2
  echo "Ly do: project install KHONG chay trong:" >&2
  echo "  - \$HOME                    ($HOME_DIR)" >&2
  echo "  - chinh repo kit           ($KIT_DIR)" >&2
  echo "  - /tmp, /var/tmp           (khong phai project that)" >&2
  echo "  - /usr, /etc, /            (system dirs)" >&2
  echo "" >&2
  echo "Cach lam dung:" >&2
  echo "" >&2
  echo "  cd /path/to/your/project" >&2
  echo "  opk install" >&2
  echo "  opk fullstack" >&2
  echo "" >&2
  echo "Neu chua co project:" >&2
  echo "" >&2
  echo "  mkdir -p ~/projects/myapp && cd ~/projects/myapp" >&2
  echo "  opk install" >&2
  echo "" >&2
}

refuse_if_bad_project_dir() {
  if is_bad_project_dir; then
    explain_blocked_dir
    err "tu choi chay trong $(pwd)"
  fi
}

# --- Subcommand dispatch ---
cmd="${1:-help}"
shift || true

case "$cmd" in
  help|--help|-h)
    cat <<EOF
opk — OpenCode Power Kit CLI (v$VERSION)

  Cách dùng nhanh:
  opk one         Cài ALL-IN-ONE: global + project + fullstack + verify (khuyến nghị) (= opk go)
  opk global      Cài global (commands/skills/agents + opk CLI)
  opk install     Cài vào project hiện tại (cần cd vào project) (= opk init)
  opk update-bmad Cập nhật BMAD Method cho project hiện tại
  opk init        Alias: opk install
  opk quick       Alias: opk global (cài global nhanh)
  opk fullstack   Cài full-stack profile (Nest/React/MySQL)
  opk all         Cài tất cả: global + project + fullstack (+ verify nếu ở project an toàn)
  opk doctor      Chẩn đoán cấu hình (read-only)
  opk verify      Kiểm tra project hiện tại
  opk tools       Detect / hướng dẫn cài rtk + tokscale
  opk bootstrap   Chạy bootstrap.sh (cài 1 lệnh, tự detect shell)
  opk go          Alias: opk one (all-in-one)
  opk path        In đường dẫn kit
  opk version     In version

  v1.6.4 — Mode & Safety (mới):
  opk mode show   Xem chế độ Power/Safe hiện tại
  opk mode power  Chuyển sang Power Mode (permission: allow)
  opk mode safe   Chuyển sang Safe Mode (permission object)
  opk safety-plugin install  Cài safety plugin guard
  opk safety-plugin status   Kiểm tra trạng thái safety plugin

  v1.3.4 — GSD Core opt-in:
  opk gsd         Forward sang official GSD installer (opt-in, version-pinned, --dry-run / --yes)
  opk gsd status  Kiểm tra GSD Core đã cài chưa (KHÔNG báo ready chỉ vì snapshot)
  opk update-gsd  Tương tự opk gsd, explicit refresh intent
  opk update-all  Pull kit (ff-only) + refresh bmad (+ optional GSD với --with-gsd)

  v1.6.5 — One Command Update & Cleanup:
  opk up          Update kit + project (git pull --ff-only + install-global)
  opk update      Alias: opk up
  opk upgrade     Alias: opk up
  opk clean       Cleanup project artifacts (mặc định dry-run)
  opk up --clean  Update + cleanup apply

  v1.6.6 — MarkItDown Tools (opt-in):
  opk markitdown install   Cài MarkItDown (npm — dry-run + confirm)
  opk markitdown status    Kiểm tra MarkItDown đã cài chưa

  v1.6.7 — Supermemory Memory API (opt-in):
  opk supermemory install   Cài Supermemory (npm — dry-run + confirm)
  opk supermemory status    Kiểm tra Supermemory đã cài chưa
  opk supermemory init      Init Supermemory (yêu cầu đã cài)
  opk supermemory init-help Xem upstream init --help (không cần cài)

  v1.7.0 — Taste Skill (optional, verify-gated):
  opk taste install          Cài Taste Skill (npx — dry-run + confirm)
  opk taste install --v1     Cài Taste Skill v1 (legacy)
  opk taste install --v2     Cài Taste Skill v2 (default)
  opk taste status           Kiểm tra Taste Skill đã cài chưa
  opk taste doctor           Kiểm tra runtime dependencies
  opk taste off              Gỡ Taste Skill (an toàn: move to .opk-trash/)
  opk taste                  Alias: opk taste status
  opk update-taste           Refresh Taste Skill
  opk taste-status           Kiểm tra nhanh (shortcut)

  v1.8.0 — ECC-lite (optional, based on Engineering Code Commandments):
  opk ecc audit     Audit codebase against ECC principles (read-only)
  opk ecc lite      Install ECC-lite components (agent + commands)
  opk ecc status    Check ECC-lite installation status
  opk ecc off       Remove ECC-lite components
  opk update-ecc    Refresh ECC-lite installation
  opk ec [...]      Alias: opk ecc
  opk e [...]       Alias: opk ecc

  v1.9.0 — Hermes-lite (optional, inspired by NousResearch Hermes Agent):
  opk hermes audit     Self-audit Hermes-lite components (read-only)
  opk hermes status    Check Hermes-lite installation status
  opk hermes capsule   Package learnings into capsule file
  opk hermes off       Remove Hermes-lite components

  v2.0.0 — Upstream Audit & Tooling:
  opk upstream audit         Scan repo for upstream refs (audit-upstreams.py)
  opk upstream audit --check CI mode (exit 1 if issues found)
  opk upstream audit --write Write docs/UPSTREAM_AUDIT.md
  opk upstream doctor        Run audit + validator + check docs
  opk superpowers status     Check superpowers plugin status
  opk superpowers reset-cache Clear superpowers cache (manual instructions)
  opk superpowers reset-cache --yes  Auto-clear (safe: move to .opk-trash/)
  opk superpowers doctor     Full superpowers diagnosis + Windows fallback
  opk bmad status            Show BMAD version pin + runtime check
  opk bmad update --stable   Update BMAD (pinned: 6.9.0)
  opk bmad update --next     Update BMAD (experimental)
  opk bmad update --version X.Y.Z  Pin BMAD to specific version
  opk tooling doctor         Detect + suggest install for dev tools

  v2.1.0 — Model-Agnostic Runtime:
  opk model status           Hiển thị model-agnostic policy (OPK không quản lý model)

Flags chung (forward cho sub-script):
  --yes   skip confirm
  --help  in trợ giúp của sub-script

Ví dụ:
  opk one                # ← khuyến nghị: cài all-in-one (cd vào project trước)
  opk go                 # tương tự opk one
  opk global             # chỉ cài global
  opk install --yes      # chỉ cài vào project hiện tại
  opk fullstack          # chỉ cài full-stack profile
  opk doctor             # chẩn đoán
  opk version
  opk bootstrap --all --yes

All-in-one one-command (Linux / macOS / Git Bash / WSL) — tự clone/pull kit rồi cài:
  bash -c 'PROJECT="\$PWD"; KIT="\$HOME/opencode-power-kit"; if [ -d "\$KIT/.git" ]; then git -C "\$KIT" pull --ff-only; else git clone https://github.com/laivannha0202/opencode-power-kit.git "\$KIT"; fi; bash "\$KIT/bootstrap.sh" --all --project-dir "\$PROJECT"; cd "\$PROJECT"; bash "\$KIT/verify.sh"'

All-in-one one-command (Windows PowerShell) — tự clone/pull kit rồi cài:
  powershell -ExecutionPolicy Bypass -Command "\$Project=(Get-Location).Path; \$KIT=Join-Path \$HOME 'opencode-power-kit'; if (Test-Path (Join-Path \$KIT '.git')) { & git -C \$KIT pull --ff-only } else { & git clone https://github.com/laivannha0202/opencode-power-kit.git \$KIT }; & (Join-Path \$KIT 'bootstrap.ps1') -All -ProjectDir \$Project -Yes; & (Join-Path \$KIT 'verify.ps1')"

Project one-command (sau khi đã cài global):
  cd /path/to/project && opk install

Kit hiện tại: $KIT_DIR
EOF
    ;;

  version|--version|-v)
    echo "opk $VERSION"
    ;;

  path)
    echo "$KIT_DIR"
    ;;

  global)
    require_file "$KIT_DIR/install-global.sh"
    exec bash "$KIT_DIR/install-global.sh" "$@"
    ;;

  install|project|init)
    refuse_if_bad_project_dir
    require_file "$KIT_DIR/install.sh"
    exec bash "$KIT_DIR/install.sh" "$@"
    ;;

  update-bmad)
    refuse_if_bad_project_dir
    require_file "$KIT_DIR/update-bmad.sh"
    exec bash "$KIT_DIR/update-bmad.sh" "$@"
    ;;

  fullstack)
    refuse_if_bad_project_dir
    require_file "$KIT_DIR/scripts/install-fullstack-profile.sh"
    exec bash "$KIT_DIR/scripts/install-fullstack-profile.sh" "$@"
    ;;

  all)
    require_file "$KIT_DIR/install-global.sh"
    require_file "$KIT_DIR/install.sh"
    require_file "$KIT_DIR/scripts/install-fullstack-profile.sh"
    require_file "$KIT_DIR/verify.sh"
    echo "opk: [1/4] install-global.sh"
    bash "$KIT_DIR/install-global.sh"
    pwd_now="$(pwd)"
    if is_bad_project_dir; then
      {
        echo "opk: BỎ QUA install.sh + fullstack + verify (pwd = $pwd_now là root nguy hiểm)." >&2
        echo "opk:   HOME / kit / / /tmp / /var/tmp / /usr / /etc đều bị từ chối." >&2
        echo "opk:   cd vào project thật, rồi chạy: opk install && opk fullstack && opk verify" >&2
      }
    else
      echo "opk: [2/4] install.sh trong $pwd_now"
      bash "$KIT_DIR/install.sh"
      echo "opk: [3/4] install-fullstack-profile.sh trong $pwd_now"
      bash "$KIT_DIR/scripts/install-fullstack-profile.sh"
      echo "opk: [4/4] verify.sh trong $pwd_now"
      bash "$KIT_DIR/verify.sh"
    fi
    ;;

  doctor)
    require_file "$KIT_DIR/doctor.sh"
    exec bash "$KIT_DIR/doctor.sh" "$@"
    ;;

  verify)
    require_file "$KIT_DIR/verify.sh"
    exec bash "$KIT_DIR/verify.sh" "$@"
    ;;

  tools)
    require_file "$KIT_DIR/scripts/install-token-tools.sh"
    exec bash "$KIT_DIR/scripts/install-token-tools.sh" "$@"
    ;;

  bootstrap)
    require_file "$KIT_DIR/bootstrap.sh"
    exec bash "$KIT_DIR/bootstrap.sh" "$@"
    ;;

  one)
    require_file "$KIT_DIR/bootstrap.sh"
    exec bash "$KIT_DIR/bootstrap.sh" --all --project-dir "$(pwd)" --yes "$@"
    ;;

  go)
    require_file "$KIT_DIR/bootstrap.sh"
    exec bash "$KIT_DIR/bootstrap.sh" --all --project-dir "$(pwd)" --yes "$@"
    ;;

  quick)
    require_file "$KIT_DIR/install-global.sh"
    exec bash "$KIT_DIR/install-global.sh" --yes "$@"
    ;;

  # ─── v1.6.4 Mode management (Power/Safe) ────────────────────────
  mode)
    mode_cmd="${1:-show}"
    shift || true
    case "$mode_cmd" in
      show)
        proj_config="$KIT_DIR/templates/opencode.json"
        if [ -f ".opencode/opencode.json" ]; then
          proj_config=".opencode/opencode.json"
        fi
        echo "opk: OpenCode Power Kit mode check"
        echo ""
        echo "Template: $KIT_DIR/templates/opencode.json"
        echo "Project:  $(test -f .opencode/opencode.json && echo '.opencode/opencode.json' || echo '(none)')"
        echo ""
        detect_py="$KIT_DIR/scripts/detect-mode.py"
        if [ -f "$detect_py" ] && command -v python3 >/dev/null 2>&1; then
          resolved="$(python3 "$detect_py" "$proj_config" 2>/dev/null || echo CUSTOM)"
        else
          # Fallback cổ điển: parse chuỗi đơn giản.
          if grep -q '"permission": "allow"' "$proj_config" 2>/dev/null; then
            resolved="POWER"
          else
            resolved="SAFE"
          fi
        fi
        case "$resolved" in
          POWER)
            echo "Current mode: POWER"
            echo "  permission == allow: Agent tự động chạy tool, sửa file, bash — không hỏi lại."
            ;;
          SAFE)
            echo "Current mode: SAFE"
            echo "  permission object: Agent hỏi trước khi write/edit/bash/task."
            ;;
          *)
            echo "Current mode: CUSTOM"
            echo "  Cấu hình không khớp POWER hay SAFE — dùng thiết lập tùy chỉnh của bạn."
            ;;
        esac
        ;;
      power)
        require_file "$KIT_DIR/templates/opencode.power.json"
        target=".opencode/opencode.json"
        if [ ! -f "$target" ]; then
          target="$KIT_DIR/templates/opencode.json"
          echo "opk: Không tìm thấy .opencode/opencode.json — cập nhật template mặc định."
        fi
        backup="${target}.bak.$(date +%Y%m%d-%H%M%S)"
        cp "$target" "$backup"
        echo "opk: Backup -> $backup"
        cp "$KIT_DIR/templates/opencode.power.json" "$target"
        echo "opk: ✅ Đã chuyển sang POWER MODE (permission: allow)"
        echo "opk:   Agent tự động chạy tool, sửa file, bash — không hỏi lại."
        echo "opk:   Safety rules enforced bằng instruction rules (xem AGENTS.md)."
        echo "opk:   Để quay lại: opk mode safe"
        ;;
      safe)
        require_file "$KIT_DIR/templates/opencode.safe.json"
        target=".opencode/opencode.json"
        if [ ! -f "$target" ]; then
          target="$KIT_DIR/templates/opencode.json"
          echo "opk: Không tìm thấy .opencode/opencode.json — cập nhật template mạĐịnh."
        fi
        backup="${target}.bak.$(date +%Y%m%d-%H%M%S)"
        cp "$target" "$backup"
        echo "opk: Backup -> $backup"
        cp "$KIT_DIR/templates/opencode.safe.json" "$target"
        echo "opk: ✅ Đã chuyển sang SAFE MODE (permission object)"
        echo "opk:   Read/grep/glob/skill=allow, write/edit/bash/task=ask."
        echo "opk:   Agent sẽ hỏi trước khi sửa file hoặc chạy lệnh."
        echo "opk:   Để quay lại: opk mode power"
        ;;
      *)
        echo "opk: mode: lệnh không hợp lệ '$mode_cmd'. Dùng: show, power, safe" >&2
        exit 1
        ;;
    esac
    ;;

  # ─── v2.1.0 Model-Agnostic ──────────────────────────────────────

  safety-plugin)
    plugin_cmd="${1:-status}"
    shift || true
    case "$plugin_cmd" in
      install)
        require_file "$KIT_DIR/scripts/install-safety-plugin.sh"
        exec bash "$KIT_DIR/scripts/install-safety-plugin.sh" "$@"
        ;;
      status)
        if [ -f ".opencode/plugins/opk-safety-guard.js" ]; then
          echo "opk: ✅ Safety plugin guard đã được cài đặt."
          echo "   File: .opencode/plugins/opk-safety-guard.js"
          wc -l ".opencode/plugins/opk-safety-guard.js" 2>/dev/null | awk '{print "   Dòng: " $1}'
        elif [ -f "$KIT_DIR/templates/plugins/opk-safety-guard.js" ]; then
          echo "opk: ⚠️ Safety plugin guard có sẵn trong template nhưng chưa cài."
          echo "   Chạy: opk safety-plugin install"
        else
          echo "opk: ℹ️ Safety plugin guard chưa được cài đặt."
        fi
        ;;
      *)
        echo "opk: safety-plugin: lệnh không hợp lệ '$plugin_cmd'. Dùng: install, status" >&2
        exit 1
        ;;
    esac
    ;;

  # ─── v1.6.5 One Command Update & Cleanup ─────────────────────────
  # opk up / opk update / opk upgrade
  #   --clean: also run cleanup-agent-artifacts.sh --apply
  # opk clean
  #   default dry-run, --apply to move
  up|update|upgrade)
    do_clean=0
    extra_args=()
    for a in "$@"; do
      case "$a" in
        --clean) do_clean=1 ;;
        -y|--yes) extra_args+=("$a") ;;
        --help|-h) echo "opk up [--clean] [--yes]"; exit 0 ;;
        *) err "opk up: flag không hợp lệ: $a" ;;
      esac
    done

    # --- Print diagnostic info ---
    echo "opk: KIT_DIR    = $KIT_DIR"
    echo "opk: opk path   = ${OPK_BIN_DIR}/opk"
    echo "opk: version    = $(cat "$KIT_DIR/VERSION" 2>/dev/null || echo '?')"
    if [ -d "$KIT_DIR/.git" ]; then
      echo "opk: git HEAD   = $(git -C "$KIT_DIR" rev-parse --short HEAD 2>/dev/null || echo '?')"
    fi
    echo "opk: VERSION    = $(cat "$KIT_DIR/VERSION" 2>/dev/null || echo '?')"
    echo ""

    # --- Git pull ---
    if [ -d "$KIT_DIR/.git" ] || git -C "$KIT_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
      # Check working tree first
      if ! git -C "$KIT_DIR" diff --quiet 2>/dev/null; then
        echo "opk: ERROR — working tree dirty, cannot pull --ff-only" >&2
        echo "opk: Dirty files:" >&2
        git -C "$KIT_DIR" status --short >&2
        echo "" >&2
        echo "opk: Hay commit thay đổi trước, hoặc dùng: opk clean" >&2
        exit 1
      fi
      echo "opk: git pull --ff-only trong $KIT_DIR"
      if ! git -C "$KIT_DIR" pull --ff-only; then
        echo "opk: ERROR — git pull failed. Kiểm tra network hoặc conflict." >&2
        exit 1
      fi
    else
      echo "opk: $KIT_DIR không phải git repo, bỏ qua pull"
    fi
    echo ""

    # --- Run install-global.sh --yes ---
    if [ -f "$KIT_DIR/install-global.sh" ]; then
      echo "opk: install-global.sh --yes"
      bash "$KIT_DIR/install-global.sh" --yes
    fi
    echo ""

    # --- Print version after update ---
    new_ver="$(cat "$KIT_DIR/VERSION" 2>/dev/null || echo '?')"
    echo "opk: version sau update = $new_ver"

    # --- Check if current dir is safe project ---
    if is_bad_project_dir; then
      echo ""
      echo "opk: pwd = $(pwd) là root nguy hiểm — bỏ qua project install."
      echo "opk:   Để update project, cd vào project thật rồi chạy:"
      echo "opk:     opk up"
      echo "opk:   Hoặc tự chạy từng bước:"
      echo "opk:     opk install --yes"
      echo "opk:     opk fullstack --yes"
      echo "opk:     opk verify"
    else
      echo ""
      echo "opk: Project dir: $(pwd)"
      echo "opk: [1/3] opk install --yes"
      bash "$KIT_DIR/install.sh" --yes
      echo "opk: [2/3] opk fullstack --yes"
      if [ -f "$KIT_DIR/scripts/install-fullstack-profile.sh" ]; then
        bash "$KIT_DIR/scripts/install-fullstack-profile.sh" --yes
      else
        echo "opk:   skip: scripts/install-fullstack-profile.sh không tồn tại"
      fi
      echo "opk: [3/3] opk verify"
      bash "$KIT_DIR/verify.sh"
    fi
    echo ""

    # --- Cleanup (dry-run mặc định, --clean thì apply) ---
    if [ -f "$KIT_DIR/scripts/cleanup-agent-artifacts.sh" ]; then
      if [ "$do_clean" -eq 1 ]; then
        echo "opk: cleanup --apply"
        bash "$KIT_DIR/scripts/cleanup-agent-artifacts.sh" --apply
      else
        echo "opk: cleanup dry-run (dùng --clean để apply)"
        bash "$KIT_DIR/scripts/cleanup-agent-artifacts.sh" --dry-run
      fi
    else
      echo "opk: skip cleanup (scripts/cleanup-agent-artifacts.sh không tồn tại)"
    fi
    echo ""
    echo "opk: ✅ Update hoàn tất."
    ;;

  clean)
    if [ -f "$KIT_DIR/scripts/cleanup-agent-artifacts.sh" ]; then
      mode="--dry-run"
      for a in "$@"; do
        case "$a" in
          --apply) mode="--apply" ;;
          --help|-h) echo "opk clean [--apply]"; exit 0 ;;
        esac
      done
      exec bash "$KIT_DIR/scripts/cleanup-agent-artifacts.sh" "$mode"
    else
      err "scripts/cleanup-agent-artifacts.sh không tồn tại"
    fi
    ;;

  # ─── v1.3.4 GSD Core opt-in integration ────────────────────────
  # Forwards to scripts/install-gsd-core.sh (calls official
  # `npx @opengsd/gsd-core@<pinned>`). Never vendors GSD source.
  gsd)
    gsd_cmd="${1:-install}"
    case "$gsd_cmd" in
      status)
        require_file "$KIT_DIR/scripts/install-gsd-core.sh"
        exec bash "$KIT_DIR/scripts/install-gsd-core.sh" status
        ;;
      install|"")
        require_file "$KIT_DIR/scripts/install-gsd-core.sh"
        exec bash "$KIT_DIR/scripts/install-gsd-core.sh" "$@"
        ;;
      *)
        echo "opk: gsd: lệnh không hợp lệ '$gsd_cmd'. Dùng: status, install (default)" >&2
        exit 1
        ;;
    esac
    ;;

  update-gsd)
    require_file "$KIT_DIR/scripts/install-gsd-core.sh"
    exec bash "$KIT_DIR/scripts/install-gsd-core.sh" "$@"
    ;;

  update-all)
    # Pull kit updates (ff-only, never reset), refresh bundled bmad,
    # optionally update GSD when --with-gsd is passed.
    with_gsd=0
    extra_args=()
    for a in "$@"; do
      case "$a" in
        --with-gsd) with_gsd=1 ;;
        --dry-run|--yes) extra_args+=("$a") ;;
        *) err "unknown flag for update-all: $a" ;;
      esac
    done
    if [ -d "$KIT_DIR/.git" ] || git -C "$KIT_DIR" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
      echo "opk: [1/3] git pull --ff-only trong $KIT_DIR"
      git -C "$KIT_DIR" pull --ff-only || echo "opk: WARN: git pull failed, continuing"
    else
      echo "opk: [1/3] $KIT_DIR không phải git repo, bỏ qua pull"
    fi
    if [ -f "$KIT_DIR/update-bmad.sh" ]; then
      echo "opk: [2/3] update-bmad.sh"
      bash "$KIT_DIR/update-bmad.sh"
    else
      echo "opk: [2/3] update-bmad.sh không tồn tại, bỏ qua"
    fi
    if [ "$with_gsd" -eq 1 ]; then
      if [ -f "$KIT_DIR/scripts/install-gsd-core.sh" ]; then
        echo "opk: [3/3] install-gsd-core.sh (--with-gsd)"
        bash "$KIT_DIR/scripts/install-gsd-core.sh" "${extra_args[@]}"
      else
        echo "opk: [3/3] scripts/install-gsd-core.sh không tồn tại, bỏ qua"
      fi
    else
      echo "opk: [3/3] bỏ qua GSD (dùng --with-gsd để chạy)"
    fi
    ;;

  # ─── v1.6.6 MarkItDown Document Tools (opt-in) ─────────────────
  markitdown)
    md_cmd="${1:-status}"
    shift || true
    case "$md_cmd" in
      install)
        require_file "$KIT_DIR/scripts/install-markitdown.sh"
        exec bash "$KIT_DIR/scripts/install-markitdown.sh" "$@"
        ;;
      status)
        if command -v markitdown >/dev/null 2>&1; then
          echo "opk: ✅ MarkItDown installed at $(command -v markitdown)"
          markitdown --help 2>&1 | head -3
        else
          echo "opk: ❌ MarkItDown not installed. Run: opk markitdown install"
        fi
        ;;
      *)
        echo "opk: markitdown: lệnh không hợp lệ '$md_cmd'. Dùng: install, status" >&2
        exit 1
        ;;
    esac
    ;;

  # ─── v1.6.7 Supermemory Memory API (opt-in) ──────────────────
  supermemory)
    sm_cmd="${1:-status}"
    shift || true
    case "$sm_cmd" in
      install)
        require_file "$KIT_DIR/scripts/install-supermemory.sh"
        exec bash "$KIT_DIR/scripts/install-supermemory.sh" "$@"
        ;;
      status)
        if command -v supermemory >/dev/null 2>&1; then
          echo "opk: ✅ Supermemory installed at $(command -v supermemory)"
          supermemory --help 2>&1 | head -3
        else
          echo "opk: ❌ Supermemory not installed. Run: opk supermemory install"
        fi
        ;;
      init)
        if ! command -v supermemory >/dev/null 2>&1; then
          err "Supermemory chưa được cài đặt. Chạy: opk supermemory install"
        fi
        echo "opk: Initializing Supermemory in $(pwd)"
        exec supermemory init "$@"
        ;;
      init-help)
        if ! command -v supermemory >/dev/null 2>&1; then
          err "Supermemory chưa được cài đặt. Chạy: opk supermemory install"
        fi
        exec supermemory init --help "$@"
        ;;
      *)
        echo "opk: supermemory: lệnh không hợp lệ '$sm_cmd'. Dùng: install, status, init, init-help" >&2
        exit 1
        ;;
    esac
    ;;

  # ─── v2.0.0 Upstream Audit & Management ──────────────────────────
  upstream)
    up_cmd="${1:-audit}"
    shift || true
    case "$up_cmd" in
      audit)
        audit_py="$KIT_DIR/scripts/audit-upstreams.py"
        require_file "$audit_py"
        if [[ "${1:-}" == "--check" ]]; then
          exec python3 "$audit_py" --check
        elif [[ "${1:-}" == "--write" ]]; then
          shift || true
          outfile="${1:-docs/UPSTREAM_AUDIT.md}"
          echo "opk: Writing upstream audit to $outfile"
          exec python3 "$audit_py" --write "$outfile"
        else
          exec python3 "$audit_py"
        fi
        ;;
      doctor)
        echo "opk: === Upstream Doctor ==="
        echo ""
        # Run audit check
        audit_py="$KIT_DIR/scripts/audit-upstreams.py"
        if [ -f "$audit_py" ]; then
          echo "opk: [1/2] Running upstream audit..."
          python3 "$audit_py" --check && echo "opk: ✅ Audit check passed" || echo "opk: ⚠️ Audit check found issues"
          echo ""
        fi
        # Run validator
        validator="$KIT_DIR/scripts/validate-opencode-pack.py"
        if [ -f "$validator" ]; then
          echo "opk: [2/2] Running pack validator..."
          python3 "$validator" && echo "opk: ✅ Validator passed" || echo "opk: ⚠️ Validator found issues"
          echo ""
        fi
        # Summary
        echo "opk: Upstream docs:"
        for doc in UPSTREAM_AUDIT.md UPSTREAM_UPDATE_POLICY.md UPSTREAM_RISKS.md; do
          if [ -f "$KIT_DIR/docs/$doc" ]; then
            echo "opk:   ✅ docs/$doc"
          else
            echo "opk:   ❌ docs/$doc missing"
          fi
        done
        ;;
      *)
        echo "opk: upstream: lệnh không hợp lệ '$up_cmd'. Dùng: audit, audit --check, doctor" >&2
        exit 1
        ;;
    esac
    ;;

  # ─── v2.0.0 Superpowers Status & Cache ──────────────────────────
  superpowers)
    sp_cmd="${1:-status}"
    shift || true
    case "$sp_cmd" in
      status)
        echo "opk: === Superpowers Status ==="
        echo ""
        # Check template plugin reference
        template_file="$KIT_DIR/templates/opencode.json"
        if [ -f "$template_file" ] && grep -q "superpowers@git+https://github.com/obra/superpowers.git" "$template_file" 2>/dev/null; then
          echo "opk: ✅ Template plugin reference: superpowers@git+https://github.com/obra/superpowers.git"
        else
          echo "opk: ❌ Template missing superpowers plugin reference"
        fi
        # Check project config
        proj_config=""
        if [ -f ".opencode/opencode.json" ]; then
          proj_config=".opencode/opencode.json"
        elif [ -f "opencode.json" ]; then
          proj_config="opencode.json"
        fi
        if [ -n "$proj_config" ] && grep -q "superpowers@git+https://github.com/obra/superpowers.git" "$proj_config" 2>/dev/null; then
          echo "opk: ✅ Project config ($proj_config) has superpowers plugin"
        elif [ -n "$proj_config" ]; then
          echo "opk: ⚠️ Project config ($proj_config) missing superpowers plugin"
        else
          echo "opk: ℹ️ No project opencode.json found (using template defaults)"
        fi
        # Check opencode on PATH
        if command -v opencode >/dev/null 2>&1; then
          echo "opk: ✅ opencode found on PATH: $(command -v opencode)"
        else
          echo "opk: ⚠️ opencode not found on PATH"
        fi
        echo ""
        echo "opk: Superpowers is loaded at runtime by OpenCode plugin system."
        echo "opk: To update, update OpenCode or follow upstream docs."
        ;;
      reset-cache)
        echo "opk: === Superpowers Cache Reset ==="
        echo ""
        echo "Superpowers cache is managed by OpenCode's plugin system."
        echo "To reset the cache manually:"
        echo ""
        echo "  1. Find the OpenCode cache directory:"
        echo "     ls ~/.cache/opencode/packages/ 2>/dev/null || ls ~/.local/share/opencode/packages/ 2>/dev/null"
        echo ""
        echo "  2. Remove the superpowers package cache:"
        echo "     rm -rf ~/.cache/opencode/packages/superpowers*"
        echo ""
        echo "  3. Or use OpenCode's built-in cache management if available."
        echo ""
        if [[ "${1:-}" == "--yes" ]]; then
          echo "opk: --yes specified, attempting safe cache clear..."
          cache_dir="${HOME}/.cache/opencode/packages"
          if [ -d "$cache_dir" ]; then
            trash_dir="${KIT_DIR}/.opk-trash/cache-reset-$(date +%Y%m%d-%H%M%S)"
            mkdir -p "$trash_dir"
            for d in "$cache_dir"/superpowers*; do
              if [ -d "$d" ]; then
                mv "$d" "$trash_dir/" 2>/dev/null && echo "opk: Moved $(basename "$d") -> $trash_dir/" || echo "opk: Could not move $(basename "$d")"
              fi
            done
            echo "opk: ✅ Cache cleared (moved to $trash_dir)"
          else
            echo "opk: No OpenCode cache directory found at $cache_dir"
          fi
        else
          echo "opk: Run with --yes to auto-clear (safe: moves to .opk-trash/)"
        fi
        ;;
      doctor)
        echo "opk: === Superpowers Doctor ==="
        echo ""
        # Run status check
        "$0" superpowers status
        echo ""
        # Windows fallback guidance
        echo "opk: Windows fallback (if git+https fails):"
        echo "  1. Use WSL or Git Bash"
        echo "  2. Or set plugin path manually in opencode.json:"
        printf '     "plugin": ["superpowers@C:\\path\\to\\superpowers"]\n'
        echo "  3. Or install via npm: npm install -g superpowers"
        echo ""
        echo "opk: Common issues:"
        echo "  - git+https requires git on PATH"
        echo "  - Corporate proxy may block GitHub access"
        echo "  - Try: git ls-remote https://github.com/obra/superpowers.git"
        ;;
      *)
        echo "opk: superpowers: lệnh không hợp lệ '$sp_cmd'. Dùng: status, reset-cache, doctor" >&2
        exit 1
        ;;
    esac
    ;;

  # ─── v2.0.0 BMAD Method Management ──────────────────────────────
  bmad)
    bmad_cmd="${1:-status}"
    shift || true
    case "$bmad_cmd" in
      status)
        echo "opk: === BMAD Method Status ==="
        echo ""
        # Current version pin
        bmad_version="${BMAD_METHOD_VERSION:-6.9.0}"
        echo "opk: BMAD_METHOD_VERSION = $bmad_version"
        echo "opk: (override via: export BMAD_METHOD_VERSION=x.y.z)"
        echo ""
        # Check .bmad/ directory
        if [ -d ".bmad" ]; then
          echo "opk: ✅ .bmad/ directory found in project"
          find .bmad/ -maxdepth 1 -type f 2>/dev/null | head -5
        else
          echo -e "opk: ℹ️ No .bmad/ directory in current project"
        fi
        echo ""
        # Check node/npm/npx
        echo "opk: Runtime check:"
        for tool in node npm npx; do
          if command -v "$tool" >/dev/null 2>&1; then
            ver=""
            case "$tool" in
              node) ver="$(node --version 2>&1)" ;;
            esac
            echo "opk:   ✅ $tool $(command -v $tool) $ver"
          else
            echo "opk:   ❌ $tool not found"
          fi
        done
        echo ""
        echo "opk: BMAD docs: https://github.com/bmad-code-org/BMAD-METHOD"
        ;;
      update)
        update_cmd="${1:---stable}"
        shift || true
        require_file "$KIT_DIR/update-bmad.sh"
        case "$update_cmd" in
          --stable)
            echo "opk: Updating BMAD Method (stable pin: 6.9.0)..."
            BMAD_METHOD_VERSION=6.9.0 exec bash "$KIT_DIR/update-bmad.sh" "$@"
            ;;
          --next)
            echo "opk: Updating BMAD Method (next/experimental)..."
            BMAD_METHOD_VERSION=next exec bash "$KIT_DIR/update-bmad.sh" "$@"
            ;;
          --version)
            ver="${1:-}"
            if [ -z "$ver" ]; then
              err "opk bmad update --version requires a version (e.g. --version 6.10.0)"
            fi
            echo "opk: Updating BMAD Method (pinned: $ver)..."
            BMAD_METHOD_VERSION="$ver" exec bash "$KIT_DIR/update-bmad.sh" "$@"
            ;;
          *)
            err "opk bmad update: flag không hợp lệ '$update_cmd'. Dùng: --stable, --next, --version <x.y.z>"
            ;;
        esac
        ;;
      *)
        echo "opk: bmad: lệnh không hợp lệ '$bmad_cmd'. Dùng: status, update --stable/--next/--version <x.y.z>" >&2
        exit 1
        ;;
    esac
    ;;

  # ─── v2.0.0 Tooling Doctor ──────────────────────────────────────
  tooling)
    tool_cmd="${1:-doctor}"
    shift || true
    case "$tool_cmd" in
      doctor)
        echo "opk: === Tooling Doctor ==="
        echo ""
        echo "opk: Detect-only tools (user-installed, never auto-installed):"
        echo ""
        # Define tools: name:install_hint
        declare -A tools=(
          [rtk]="cargo install rtk"
          [repomix]="npm i -g repomix"
          ["ast-grep"]="cargo install ast-grep"
          [rg]="brew install ripgrep  # or cargo install ripgrep"
          [fd]="brew install fd  # or cargo install fd"
          [knip]="npm i -g knip"
          [gitleaks]="brew install gitleaks  # or go install github.com/gitleaks/gitleaks/v2"
          [trufflehog]="brew install trufflehog  # or go install github.com/trufflesecurity/trufflehog/v3"
          [semgrep]="pip install semgrep  # or brew install semgrep"
          [spectral]="npm i -g @stoplight/spectral-cli"
          [oasdiff]="brew install oasdiff  # or go install github.com/tufin/oasdiff"
          [playwright]="npm i -g playwright  # or npx playwright install"
          [biome]="npm i -g @biomejs/biome"
        )
        for tool in rtk repomix ast-grep rg fd knip gitleaks trufflehog semgrep spectral oasdiff playwright biome; do
          hint="${tools[$tool]:-}"
          if command -v "$tool" >/dev/null 2>&1; then
            ver=""
            case "$tool" in
              rg) ver="$(rg --version 2>&1 | head -1)" ;;
              fd) ver="$(fd --version 2>&1 | head -1)" ;;
              node) ver="$(node --version 2>&1)" ;;
              *) ver="$($tool --version 2>&1 | head -1)" ;;
            esac
            echo "opk:   ✅ $tool $ver"
          else
            echo "opk:   ❌ $tool — install: $hint"
          fi
        done
        echo ""
        # Also run doctor.sh if available
        if [ -f "$KIT_DIR/doctor.sh" ]; then
          echo "opk: Running full doctor.sh..."
          echo ""
          bash "$KIT_DIR/doctor.sh"
        fi
        ;;
      *)
        echo "opk: tooling: lệnh không hợp lệ '$tool_cmd'. Dùng: doctor" >&2
        exit 1
        ;;
    esac
    ;;

  # ─── v2.0.0 Taste Skill (verify-gated, optional) ────────────────
  taste|taste-status|taste-off|update-taste)
    case "$cmd" in
      taste-off)
        taste_skill_dir="${HOME}/.config/opencode/skills/taste-skill"
        if [[ -d "$taste_skill_dir" ]]; then
          echo "opk: Xoá Taste Skill tại $taste_skill_dir"
          # Safe removal: move to .opk-trash instead of rm -rf
          trash_dir="${KIT_DIR}/.opk-trash/taste-skill-$(date +%Y%m%d-%H%M%S)"
          mkdir -p "$trash_dir"
          mv "$taste_skill_dir" "$trash_dir/" 2>/dev/null && echo "opk: ✅ Đã di chuyển Taste Skill -> $trash_dir" || echo "opk: ⚠️ Không thể di chuyển, thử xóa an toàn..."
          echo "opk: ✅ Đã gỡ Taste Skill."
        else
          echo "opk: ℹ️ Taste Skill chưa được cài đặt."
        fi
        exit 0
        ;;
      update-taste)
        require_file "$KIT_DIR/scripts/install-taste-skill.sh"
        exec bash "$KIT_DIR/scripts/install-taste-skill.sh" "$@"
        ;;
      taste-status)
        echo "opk: === Taste Skill Status ==="
        taste_skill_dir="${HOME}/.config/opencode/skills/taste-skill"
        if [[ -d "$taste_skill_dir" ]]; then
          echo "opk: ✅ Taste Skill directory exists: $taste_skill_dir"
          if [[ -f "$taste_skill_dir/SKILL.md" ]]; then
            echo "opk: ✅ SKILL.md found"
            # Try to parse frontmatter
            name=$(grep -m1 "^name:" "$taste_skill_dir/SKILL.md" 2>/dev/null | sed 's/name:[[:space:]]*//')
            desc=$(grep -m1 "^description:" "$taste_skill_dir/SKILL.md" 2>/dev/null | sed 's/description:[[:space:]]*//')
            if [ -n "$name" ]; then
              echo "opk: ✅ name: $name"
            else
              echo "opk: ⚠️ SKILL.md missing 'name' in frontmatter"
            fi
            if [ -n "$desc" ]; then
              echo "opk: ✅ description: ${desc:0:80}..."
            else
              echo "opk: ⚠️ SKILL.md missing 'description' in frontmatter"
            fi
          else
            echo "opk: ❌ SKILL.md not found in $taste_skill_dir"
          fi
        else
          echo "opk: ❌ Taste Skill not installed"
          echo "opk: Run: opk taste install"
        fi
        exit 0
        ;;
      taste)
        taste_cmd="${1:-status}"
        shift || true
        case "$taste_cmd" in
          install)
            install_flags=()
            version=""
            for a in "$@"; do
              case "$a" in
                --v1) version="v1" ;;
                --v2) version="v2" ;;
                --dry-run|--yes) install_flags+=("$a") ;;
                -h|--help)
                  echo "Usage: opk taste install [--v1|--v2] [--dry-run] [--yes]"
                  echo ""
                  echo "  --v1    Install Taste Skill v1 (legacy, specific skill name)"
                  echo "  --v2    Install Taste Skill v2 (default, latest)"
                  echo "  --dry-run  Print plan without installing"
                  echo "  --yes      Skip confirmation"
                  exit 0
                  ;;
                *) err "flag không hợp lệ: $a" ;;
              esac
            done
            if [ "$version" = "v1" ]; then
              echo "opk: Installing Taste Skill v1 (legacy)..."
              echo "opk: Command: npx skills add https://github.com/Leonxlnx/taste-skill --skill \"design-taste-frontend-v1\""
              if [[ " ${install_flags[*]} " == *" --dry-run "* ]]; then
                echo "opk: Dry run — not installing."
                exit 0
              fi
              if [[ " ${install_flags[*]} " == *" --yes "* ]]; then
                exec npx skills add "https://github.com/Leonxlnx/taste-skill" --skill "design-taste-frontend-v1"
              else
                read -r -p "Install Taste Skill v1? [y/N] " reply
                case "$reply" in y|Y|yes|YES) exec npx skills add "https://github.com/Leonxlnx/taste-skill" --skill "design-taste-frontend-v1" ;; *) echo "aborted."; exit 0 ;; esac
              fi
            else
              # Default: v2
              require_file "$KIT_DIR/scripts/install-taste-skill.sh"
              exec bash "$KIT_DIR/scripts/install-taste-skill.sh" "${install_flags[@]}"
            fi
            ;;
          status|"")
            # Same as taste-status above
            "$0" taste-status
            ;;
          off)
            "$0" taste-off
            ;;
          doctor)
            echo "opk: === Taste Skill Doctor ==="
            echo ""
            echo "opk: Runtime check:"
            for tool in node npm npx; do
              if command -v "$tool" >/dev/null 2>&1; then
                echo "opk:   ✅ $tool $(command -v $tool)"
              else
                echo "opk:   ❌ $tool not found (required for Taste Skill)"
              fi
            done
            echo ""
            echo "opk: Skill discovery:"
            taste_skill_dir="${HOME}/.config/opencode/skills/taste-skill"
            if [[ -d "$taste_skill_dir" ]]; then
              echo "opk:   ✅ Skill directory exists: $taste_skill_dir"
            else
              echo "opk:   ❌ Skill directory missing: $taste_skill_dir"
            fi
            echo ""
            echo "opk: OpenCode config check:"
            for cfg in ".opencode/opencode.json" "opencode.json" "$KIT_DIR/templates/opencode.json"; do
              if [ -f "$cfg" ] && grep -q "taste" "$cfg" 2>/dev/null; then
                echo "opk:   ✅ $cfg references taste skill"
                break
              fi
            done
            echo ""
            echo "opk: Install command: opk taste install"
            echo "opk: OPK_SKIP_TASTE=1 skips auto-install during global setup"
            ;;
          *)
            echo "opk: taste: lệnh không hợp lệ '$taste_cmd'. Dùng: install [--v1|--v2], status, off, doctor" >&2
            exit 1
            ;;
        esac
    ;;
  esac
    ;;

  # ─── v1.8.0 ECC-lite (optional, based on Engineering Code Commandments) ──
  # ECC: Engineering Code Commandments by affaan.m
  # Lightweight integration: 6 principles, audit + lite agent + commands
  # Full ECC: https://github.com/affaan-m/ECC
  ec|e|ecc)
    ecc_cmd="${1:-status}"
    shift || true
    case "$ecc_cmd" in
      audit)
        require_file "$KIT_DIR/scripts/audit-ecc.sh"
        exec bash "$KIT_DIR/scripts/audit-ecc.sh" "$@"
        ;;
      lite)
        require_file "$KIT_DIR/scripts/install-ecc-lite.sh"
        exec bash "$KIT_DIR/scripts/install-ecc-lite.sh" "$@"
        ;;
      status)
        require_file "$KIT_DIR/scripts/check-ecc-lite.sh"
        exec bash "$KIT_DIR/scripts/check-ecc-lite.sh" "$@"
        ;;
      off)
        # Determine config dir: prefer OPENCODE_CONFIG_DIR
        if [[ -n "${OPENCODE_CONFIG_DIR:-}" ]]; then
          ECC_CONFIG_BASE="${OPENCODE_CONFIG_DIR}"
        else
          ECC_CONFIG_BASE="${HOME}/.config/opencode"
        fi
        ecc_removed=0
        # Remove ECC-lite components
        ecc_target="${ECC_CONFIG_BASE}/agents/ecc-lite-strong.md"
        if [[ -f "$ecc_target" ]]; then
          rm -f "$ecc_target"
          echo "opk: ✅ Đã xoá agent ecc-lite-strong.md"
          ecc_removed=1
        fi
        # Also check bundled location if different from config base
        if [[ "${ECC_CONFIG_BASE}" != "${KIT_DIR}/opencode-global" ]]; then
          bundled="${KIT_DIR}/opencode-global/agents/ecc-lite-strong.md"
          if [[ -f "$bundled" ]]; then
            echo "opk: ℹ️  Agent tồn tại trong kit bundle (không xoá): ${bundled}"
          fi
        fi
        # Remove ECC commands
        for cmd_file in ecc-audit.md quality-gate.md research-first.md verify-loop.md model-route-review.md harness-audit.md; do
          cmd_path="${ECC_CONFIG_BASE}/commands/$cmd_file"
          if [[ -f "$cmd_path" ]]; then
            rm -f "$cmd_path"
            echo "opk: ✅ Đã xoá command $cmd_file"
            ecc_removed=1
          fi
        done
        if [[ $ecc_removed -eq 0 ]]; then
          echo "opk: ℹ️ ECC-lite chưa được cài đặt."
        else
          echo "opk: ✅ Đã gỡ ECC-lite hoàn tất."
        fi
        exit 0
        ;;
      *)
        echo "opk: ecc: lệnh không hợp lệ '$ecc_cmd'. Dùng: audit, lite, status, off" >&2
        exit 1
        ;;
    esac
    ;;

  update-ecc)
    require_file "$KIT_DIR/scripts/install-ecc-lite.sh"
    exec bash "$KIT_DIR/scripts/install-ecc-lite.sh" "$@"
    ;;

  # ─── v1.9.0 Hermes-lite (optional, meta-cognitive self-improvement) ─
  # Inspired by Hermes Agent (NousResearch) — OPK-native, no full Hermes.
  hermes|hermes-status|hermes-off)
    hermes_cmd="${1:-status}"
    shift || true
    case "$hermes_cmd" in
      audit)
        require_file "$KIT_DIR/scripts/audit-hermes.sh"
        exec bash "$KIT_DIR/scripts/audit-hermes.sh" "$@"
        ;;
      status)
        require_file "$KIT_DIR/scripts/check-hermes-lite.sh"
        exec bash "$KIT_DIR/scripts/check-hermes-lite.sh" "$@"
        ;;
      capsule)
        require_file "$KIT_DIR/scripts/hermes-learning-capsule.sh"
        exec bash "$KIT_DIR/scripts/hermes-learning-capsule.sh" "$@"
        ;;
      off)
        hermes_removed=0
        if [[ -n "${OPENCODE_CONFIG_DIR:-}" ]]; then
          HERMES_CONFIG_BASE="${OPENCODE_CONFIG_DIR}"
        else
          HERMES_CONFIG_BASE="${HOME}/.config/opencode"
        fi
        h_target="${HERMES_CONFIG_BASE}/agents/hermes-lite-strong.md"
        if [[ -f "$h_target" ]]; then
          rm -f "$h_target"
          echo "opk: ✅ Đã xoá agent hermes-lite-strong.md"
          hermes_removed=1
        fi
        for cmd_file in hermes-reflect.md hermes-skill.md hermes-kanban.md hermes-memory.md hermes-budget.md hermes-audit.md hermes-learn.md hermes-research.md; do
          cmd_path="${HERMES_CONFIG_BASE}/commands/$cmd_file"
          if [[ -f "$cmd_path" ]]; then
            rm -f "$cmd_path"
            echo "opk: ✅ Đã xoá command $cmd_file"
            hermes_removed=1
          fi
        done
        if [[ $hermes_removed -eq 0 ]]; then
          echo "opk: ℹ️  Hermes-lite chưa được cài đặt."
        else
          echo "opk: ✅ Đã gỡ Hermes-lite hoàn tất."
        fi
        exit 0
        ;;
      help|--help|-h)
        echo "opk hermes audit        Self-audit Hermes-lite components"
        echo "opk hermes status       Check Hermes-lite installation status"
        echo "opk hermes capsule      Package learnings into capsule (from .hermes/learnings/)"
        echo "opk hermes off          Remove Hermes-lite components"
        exit 0
        ;;
      *)
        echo "opk: hermes: lệnh không hợp lệ '$hermes_cmd'. Dùng: audit, status, capsule, off, help" >&2
        exit 1
        ;;
    esac
    ;;

  # ─── v1.6.6 MarkItDown Document Tools (opt-in) ─────────────────
  md-convert|doc-to-md)
    # opk md-convert <input> <output> [--force]
    # opk doc-to-md <input> <output> [--force]
    if ! command -v markitdown >/dev/null 2>&1; then
      err "MarkItDown chưa được cài đặt. Chạy: opk markitdown install"
    fi
    if [[ $# -lt 2 ]]; then
      echo "Usage: opk $cmd <input-file> <output-file> [--force]" >&2
      exit 1
    fi
    input="$1"
    output="$2"
    shift 2
    force=0
    for a in "$@"; do
      case "$a" in
        --force) force=1 ;;
        *) err "flag không hợp lệ: $a" ;;
      esac
    done
    # Validate input exists
    if [[ ! -f "$input" ]]; then
      err "input file không tồn tại: $input"
    fi
    # Check output does not exist
    if [[ -f "$output" && "$force" -eq 0 ]]; then
      err "output file đã tồn tại: $output (dùng --force để ghi đè)"
    fi
    # Don't read .env/secrets
    case "$input" in
      *.env|*.secret|*secret*|*private*|*key*|*credential*|*token*)
        err "từ chối convert file nhạy cảm: $input"
        ;;
    esac
    echo "opk: Converting $input -> $output"
    markitdown "$input" > "$output"
    echo "opk: ✅ Done ($(wc -c < "$output") bytes)"
    ;;

  # ─── Model-Agnostic: OPK không quản lý model ─────────────────
  model)
    model_cmd="${1:-status}"
    shift || true

    case "$model_cmd" in
      status)
        echo "opk: Model-agnostic mode — OPK không quản lý model."
        echo "    Chọn model trong OpenCode UI (Settings → Model)."
        echo "    Tất cả agent OPK inherit model đó."
        echo ""
        if command -v opencode &>/dev/null; then
          echo "    OpenCode version: $(opencode --version 2>/dev/null || echo 'unknown')"
        fi
        exit 0
        ;;
      help|--help|-h)
        echo "opk model status    Hiển thị model-agnostic policy"
        echo ""
        echo "OPK không chọn, route, benchmark, hay override model."
        echo "User tự chọn model trong OpenCode UI."
        exit 0
        ;;
      *)
        echo "opk: model: '$model_cmd' không hỗ trợ. OPK model-agnostic — chỉ dùng 'opk model status'." >&2
        exit 1
        ;;
    esac
    ;;

  *)
    err "lệnh không hợp lệ: '$cmd'. Chạy 'opk help'."
    ;;
esac
