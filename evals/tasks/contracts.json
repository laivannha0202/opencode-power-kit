[
  {
    "id": "contract-001",
    "name": "No model routing in bin/opk",
    "description": "bin/opk must not contain model discovery, routing, or benchmark commands",
    "check_type": "grep_absent",
    "target": "bin/opk",
    "patterns": [
      "discover-free",
      "list-free",
      "benchmark-free",
      "route-free",
      "opk-model-discover",
      "opk-model-route",
      "opk-model-benchmark",
      "FREE_ONLY",
      "opencode run --model"
    ],
    "expected": "all_absent"
  },
  {
    "id": "contract-002",
    "name": "No API keys in templates",
    "description": "Template files must not contain API key references",
    "check_type": "grep_absent",
    "target": "templates/",
    "patterns": [
      "ANTHROPIC_API_KEY",
      "OPENAI_API_KEY",
      "api_key",
      "API_KEY"
    ],
    "expected": "all_absent"
  },
  {
    "id": "contract-003",
    "name": ".gitignore allows .opencode/",
    "description": ".gitignore must not block .opencode/ directory",
    "check_type": "grep_absent",
    "target": ".gitignore",
    "patterns": [
      "^\\.opencode/$",
      "opk-free-models"
    ],
    "expected": "all_absent"
  },
  {
    "id": "contract-004",
    "name": "No model routing scripts exist",
    "description": "Deleted model scripts must not exist",
    "check_type": "file_absent",
    "targets": [
      "scripts/opk-model-discover.sh",
      "scripts/opk-model-route.sh",
      "scripts/opk-model-benchmark.sh",
      "scripts/validate-free-model.sh"
    ],
    "expected": "all_absent"
  },
  {
    "id": "contract-005",
    "name": "Safety plugin uses correct pattern",
    "description": "test-safety-plugin.mjs must pass",
    "check_type": "script_exec",
    "command": "node scripts/test-safety-plugin.mjs",
    "expected": "exit_0"
  },
  {
    "id": "contract-006",
    "name": "Permission ordering correct",
    "description": "test-permission-rules.py must pass — wildcard before deny",
    "check_type": "script_exec",
    "command": "python3 scripts/test-permission-rules.py",
    "expected": "exit_0"
  },
  {
    "id": "contract-007",
    "name": "No model override template",
    "description": "opencode.models.example.jsonc must not exist",
    "check_type": "file_absent",
    "targets": [
      "templates/opencode.models.example.jsonc"
    ],
    "expected": "all_absent"
  },
  {
    "id": "contract-008",
    "name": "Model-agnostic policy documented",
    "description": "docs/MODEL_ROUTING.md must exist and contain model-agnostic language",
    "check_type": "grep_present",
    "target": "docs/MODEL_ROUTING.md",
    "patterns": [
      "model-agnostic",
      "không chọn",
      "không route"
    ],
    "expected": "all_present"
  },
  {
    "id": "contract-009",
    "name": "Model status via opk CLI",
    "description": "bin/opk model status must run and output model-agnostic policy",
    "check_type": "script_exec",
    "command": "bin/opk model status",
    "expected": "exit_0"
  },
  {
    "id": "contract-010",
    "name": "No model override in agent files",
    "description": "Agent .md files must not contain model: override lines",
    "check_type": "grep_absent",
    "target": "opencode-global/agents/",
    "patterns": [
      "^model:"
    ],
    "expected": "all_absent"
  },
  {
    "id": "contract-011",
    "name": "Writer/read-only reviewer policy",
    "description": "build-strong must define reviewer as read-only",
    "check_type": "grep_present",
    "target": "opencode-global/agents/build-strong.md",
    "patterns": [
      "Reviewer read-only",
      "read-only"
    ],
    "expected": "all_present"
  },
  {
    "id": "contract-012",
    "name": "build-strong pipeline stages",
    "description": "build-strong must define all 7 pipeline stages",
    "check_type": "grep_present",
    "target": "opencode-global/agents/build-strong.md",
    "patterns": [
      "Intake",
      "Context",
      "Plan",
      "Implement",
      "Review",
      "Verify",
      "Report"
    ],
    "expected": "all_present"
  }
]
