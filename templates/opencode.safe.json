{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git"
  ],
  "instructions": [
    "AGENTS.md",
    "OPENCODE.md"
  ],
  "permission": {
    "*": "ask",
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "skill": "allow",
    "search": "allow",
    "write": "ask",
    "edit": "ask",
    "bash": {
      "*": "ask",
      "pwd": "allow",
      "ls *": "allow",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "rg *": "allow",
      "fd *": "allow",
      "cat *": "ask",
      "npm test*": "ask",
      "npm run test*": "ask",
      "npm run lint*": "ask",
      "npm run typecheck*": "ask",
      "python3 scripts/validate-opencode-pack.py*": "allow",
      "bash verify.sh*": "ask",
      "bash doctor.sh*": "ask",
      "rm -rf*": "deny",
      "rm -fr*": "deny",
      "sudo rm -rf*": "deny",
      "sudo rm -fr*": "deny",
      "git reset --hard*": "deny",
      "git clean -f*": "deny",
      "git push --force*": "deny",
      "git push -f*": "deny",
      "*DROP TABLE*": "deny",
      "*TRUNCATE TABLE*": "deny",
      "*DELETE FROM*": "deny",
      "curl *| *sh*": "deny",
      "wget *| *sh*": "deny"
    },
    "task": "ask"
  }
}
