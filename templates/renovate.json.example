{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":automergeMinor",
    ":automergePatch",
    "group:allNonMajor",
    "schedule:weekends"
  ],
  "timezone": "Asia/Ho_Chi_Minh",
  "labels": ["renovate", "dependencies"],
  "prConcurrentLimit": 10,
  "prHourlyLimit": 4,
  "commitMessageTopic": "deps",
  "commitMessageAction": "update",
  "semanticCommits": "enabled",
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 6am on monday"]
  },
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security", "renovate"],
    "assignees": [],
    "reviewers": []
  },
  "packageRules": [
    {
      "description": "Group all patch updates in one PR",
      "matchUpdateTypes": ["patch"],
      "groupName": "patch updates",
      "automerge": true
    },
    {
      "description": "Group all minor updates in one PR",
      "matchUpdateTypes": ["minor"],
      "groupName": "minor updates",
      "automerge": true
    },
    {
      "description": "Major updates need manual review",
      "matchUpdateTypes": ["major", "digest"],
      "groupName": "major updates",
      "automerge": false,
      "labels": ["breaking-change"]
    },
    {
      "description": "Pin build tooling to exact version",
      "matchPackageNames": [
        "typescript",
        "vite",
        "webpack",
        "esbuild",
        "@nestjs/core",
        "@nestjs/cli"
      ],
      "matchUpdateTypes": ["major", "minor"],
      "enabled": false
    },
    {
      "description": "Ignore test fixtures and snapshots",
      "paths": ["**/__tests__/**", "**/test/**", "**/tests/**", "**/*.snap"],
      "enabled": false
    }
  ],
  "ignorePaths": [
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/coverage/**"
  ]
}
