{
  // ============================================================================
  // opencode.models.example.jsonc
  // Model routing example — free-model orchestration.
  //
  // Place tại project root hoặc .opencode/opencode.json.
  // Chỉ cần cấu hình "model" mặc định. Per-agent model là optional.
  //
  // IMPORTANT: OPK KHÔNG quản lý API key. Người dùng đăng nhập
  // provider bằng giao diện OpenCode hoặc /connect.
  // OPK chỉ dùng các model mà `opencode models` trả về.
  // ============================================================================

  "$schema": "https://opencode.ai/config.json",

  // Model mặc định cho mọi task.
  // Lấy exact ID từ: opencode models --refresh --verbose
  // Không hardcode model slug — danh sách free có thể thay đổi.
  "model": "REPLACE_WITH_OUTPUT_FROM_OPENCODE_MODELS",

  // Optional: Per-agent model routing.
  // Override model mặc định cho từng agent.
  // Nếu bỏ trống hoặc không có key, dùng model mặc định ở trên.
  //
  // Mode values:
  //   - "primary": model chính cho agent này
  //   - "subagent": model cho subagent tasks
  //   - "all": model cho tất cả modes
  //
  // Model format: "provider/exact-model-id"
  // Lấy ID từ: opencode models --refresh --verbose
  "agent": {
    // Build agent — model mạnh nhất cho code generation, refactoring.
    "build": {
      "mode": "primary",
      "model": "REPLACE_WITH_BEST_FREE_MODEL"
    },

    // Exploration agent — model nhanh, rẻ cho read-only tasks.
    "explore": {
      "mode": "subagent",
      "model": "REPLACE_WITH_SECOND_FREE_MODEL"
    },

    // Build-strong agent — model mạnh cho implementation phức tạp.
    "build-strong": {
      "mode": "primary",
      "model": "REPLACE_WITH_BEST_FREE_MODEL"
    },

    // Debug agent — model analytical cho root cause analysis.
    "debug-strong": {
      "mode": "all",
      "model": "REPLACE_WITH_THIRD_FREE_MODEL"
    }
  }

  // Permission, instructions, plugins, MCP, formatter — giữ nguyên
  // từ template chính. Không cần khai báo lại ở đây trừ khi override.
}
