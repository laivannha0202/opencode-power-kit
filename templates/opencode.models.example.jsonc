{
  // ============================================================================
  // opencode.models.example.jsonc
  // Model routing example — copy và tùy chỉnh cho project của bạn.
  //
  // Place tại project root hoặc .opencode/opencode.json.
  // Chỉ cần cấu hình "model" mặc định. Per-agent model là optional.
  // ============================================================================

  "$schema": "https://opencode.ai/config.json",

  // Model mặc định cho mọi task.
  // Format: "provider/model-name"
  "model": "anthropic/claude-sonnet-4-20250514",

  // Provider definitions — API keys từ env vars.
  "provider": {
    "anthropic": {
      "apiKey": "env:ANTHROPIC_API_KEY"
    },
    "openai": {
      "apiKey": "env:OPENAI_API_KEY"
    }
    // Thêm provider khác tùy needs:
    // "google": { "apiKey": "env:GOOGLE_API_KEY" },
    // "deepseek": { "apiKey": "env:DEEPSEEK_API_KEY" }
  },

  // Optional: Per-agent model routing.
  // Override model mặc định cho từng agent.
  // Nếu bỏ trống hoặc không có key, dùng model mặc định ở trên.
  //
  // Mode values:
  //   - "primary": model chính cho agent này
  //   - "subagent": model cho subagent tasks
  //   - "all": model cho tất cả modes
  //
  // Model format: "provider/model-name" (vd: "anthropic/claude-sonnet-4-20250514")
  "agent": {
    // Build agent — model mạnh nhất cho code generation, refactoring.
    "build": {
      "mode": "primary",
      "model": "anthropic/claude-sonnet-4-20250514"
    },

    // Exploration agent — model nhanh, rẻ cho read-only tasks.
    "explore": {
      "mode": "subagent",
      "model": "anthropic/claude-haiku-3-20240307"
    },

    // Build-strong agent — model mạnh cho implementation phức tạp.
    "build-strong": {
      "mode": "primary",
      "model": "anthropic/claude-sonnet-4-20250514"
    },

    // Debug agent — model analytical mạnh nhất cho root cause analysis.
    "debug-strong": {
      "mode": "all",
      "model": "anthropic/claude-opus-4-20250514"
    }
  }

  // Permission, instructions, plugins, MCP, formatter — giữ nguyên
  // từ template chính. Không cần khai báo lại ở đây trừ khi override.
}
